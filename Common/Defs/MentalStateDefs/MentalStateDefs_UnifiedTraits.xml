  <MentalStateDef ParentName="BaseMentalState">
      <defName>UT_HVT_VisionaryEureka</defName>
      <workerClass>HautsTraits.MentalStateWorker_Eureka</workerClass>
      <stateClass>HautsTraits.MentalState_Eureka</stateClass>
      <label>created a schematic</label>
      <category>Misc</category>
