<?xml version='1.0' encoding='utf-8'?>
<Defs>
  <MentalStateDef ParentName="Tantrum">
      <defName>UT_VTE_TechnophobeTantrum</defName>
      <stateClass>VanillaTraitsExpanded.MentalState_TechnophobeTantrum</stateClass>
      <workerClass>VanillaTraitsExpanded.MentalStateWorker_TechnophobeTantrum</workerClass>
      <label>technophobe tantrum</label>
      <maxTicksBeforeRecovery>30000</maxTicksBeforeRecovery>
      <recoveryMessage>{0} is no longer in a technophobe tantrum.</recoveryMessage>
      <beginLetterDef>ThreatSmall</beginLetterDef>
      <beginLetter>{0} has flown into a technophobe tantrum.\n\n[PAWN_pronoun] is going to vent [PAWN_possessive] anger on technology.</beginLetter>
      <baseInspectLine>Mental state: technophobe tantrum</baseInspectLine>
    </MentalStateDef>

  <MentalStateDef ParentName="BaseMentalState">
      <defName>UT_VTE_PanicFreezing</defName>
      <label>panic freezing</label>
      <stateClass>VanillaTraitsExpanded.MentalState_PanicFreezing</stateClass>
      <category>Misc</category>
      <blockInteractionInitiationExcept>
        <li>Insult</li>
      </blockInteractionInitiationExcept>
      <blockInteractionRecipientExcept>
        <li>Insult</li>
      </blockInteractionRecipientExcept>
      <blockRandomInteraction>true</blockRandomInteraction>
      <nameColor>(0.65, 0.9, 0.93)</nameColor>
      <beginLetterLabel>panic attack</beginLetterLabel>
      <beginLetter>{0} is freezing in panic.</beginLetter>
      <recoveryMessage>{0} is no longer freezing in panic.</recoveryMessage>
      <baseInspectLine>Mental state: freezing in panic</baseInspectLine>
  	<stateEffecter>UT_VTE_PanicFreezing</stateEffecter>
      <blockNormalThoughts>true</blockNormalThoughts>
      <unspawnedCanDo>true</unspawnedCanDo>
    </MentalStateDef>

  <MentalStateDef ParentName="BaseMentalState">
      <defName>UT_VTE_Kleptomaniac</defName>
      <stateClass>VanillaTraitsExpanded.MentalState_Kleptomaniac</stateClass>
      <workerClass>VanillaTraitsExpanded.MentalStateWorker_Kleptomaniac</workerClass>
      <label>kleptomaniac</label>
      <category>Misc</category>
      <prisonersCanDo>false</prisonersCanDo>
      <colonistsOnly>true</colonistsOnly>
      <minTicksBeforeRecovery>25000</minTicksBeforeRecovery>
      <maxTicksBeforeRecovery>45000</maxTicksBeforeRecovery>
      <recoveryMtbDays>0.166</recoveryMtbDays>
      <recoverFromSleep>true</recoverFromSleep>
      <nameColor>(0.5, 0.9, 0.5)</nameColor>
      <beginLetterLabel>Kleptomaniac</beginLetterLabel>
      <beginLetter>{0} is stealing items from visitors.</beginLetter>
      <beginLetterDef>NegativeEvent</beginLetterDef>
      <moodRecoveryThought>Catharsis</moodRecoveryThought>
      <recoveryMessage>{0} is no longer stealing items from visitors.</recoveryMessage>
      <baseInspectLine>Mental state: Kleptomaniac</baseInspectLine>
      <allowBeatfire>true</allowBeatfire>
      <escapingPrisonersIgnore>true</escapingPrisonersIgnore>
    </MentalStateDef>

  <MentalStateDef ParentName="BaseMentalState">
  		<defName>UT_BOT_ClaustrophobicBreak</defName>
  		<stateClass>More_Traits.MentalStates.MentalStates.MentalState_ClaustrophobicState</stateClass>
  		<workerClass>More_Traits.MentalStates.MentalStateWorkers.MentalStateWorker_ClaustrophobicPanic</workerClass>
  		<label>claustrophobic panic attack</label>
  		<category>Misc</category>
  		<blockRandomInteraction>true</blockRandomInteraction>
  		<blockInteractionInitiationExcept />
  		<blockInteractionRecipientExcept>
  			<li>Insult</li>
  		</blockInteractionRecipientExcept>
  		<moodRecoveryThought>UT_BOT_ClaustrophobicBreakRecovered</moodRecoveryThought>
  		<blockNormalThoughts>true</blockNormalThoughts>
  		<nameColor>(0.6171, 0.2578, 0.957)</nameColor>
  		<beginLetter>{0} has gone into a claustrophobic panic attack.\n\n[PAWN_pronoun] will experience severe symptoms related to it.</beginLetter>
  		<beginLetterDef>ThreatSmall</beginLetterDef>
  		<minTicksBeforeRecovery>10000</minTicksBeforeRecovery>
  		<maxTicksBeforeRecovery>30000</maxTicksBeforeRecovery>
  		<recoveryMtbDays>0.3</recoveryMtbDays>
  		<recoveryMessage>{0}'s panic attack has ended.</recoveryMessage>
  		<baseInspectLine>Mental state: Claustrophobic panic attack</baseInspectLine>
  		<stateEffecter>BOT_ClaustrophobicEffector</stateEffecter>
  		<tale>BOT_ClaustrophobicTale</tale>
  		<recoverFromSleep>true</recoverFromSleep>
  		<unspawnedNotInCaravanCanDo>true</unspawnedNotInCaravanCanDo>
  	</MentalStateDef>

  <MentalStateDef>
  		<defName>UT_BOT_NarcolepticAsleep</defName>
  		<label>Narcoleptic</label>
  		<description>{PAWN_nameDef} fell asleep due to {PAWN_possessive} narcolepsy.</description>
  		<baseInspectLine>The pawn is asleep.</baseInspectLine>
  		<category>Misc</category>
  		<inCaravanCanDo>false</inCaravanCanDo>
  		<downedCanDo>true</downedCanDo>
  		<blockRandomInteraction>true</blockRandomInteraction>
  		<drugCategory>None</drugCategory>
  		<modExtensions>
  			<li Class="More_Traits.ModExtensions.BOT_MentalStateExtension">
  				<traitDef>UT_BOT_Narcoleptic</traitDef>
  			</li>
  		</modExtensions>
  		<recoveryMtbDays>0.01</recoveryMtbDays>
  		<recoveryMessage>{PAWN} woke up from his narcoleptic sleep.</recoveryMessage>
  		<minTicksBeforeRecovery>300</minTicksBeforeRecovery>
  		<maxTicksBeforeRecovery>10000</maxTicksBeforeRecovery>
  		<stateClass>More_Traits.MentalStates.MentalStates.BOT_NarcolepticAsleepState</stateClass>
  		<workerClass>More_Traits.MentalStates.MentalStateWorkers.BOT_TraitMentalStateWorker</workerClass>
  		<stopsJobs>false</stopsJobs>
  	</MentalStateDef>

