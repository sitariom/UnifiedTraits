  <TraitDef>
      <defName>UT_Natural</defName>
      <commonality>0.5</commonality>
      <degreeDatas>
          <li>
              <label>Natural Purity</label>
              <description>{PAWN_nameDef}'s body and mind are completely pure, deeply resonant with nature. Any implants are superfluous to {PAWN_objective}, causing distress if installed.</description>
              <statOffsets>
                  <WorkSpeedGlobal>0.2</WorkSpeedGlobal> 
              </statOffsets>
              <allowedMeditationFocusTypes><li>UT_Natural</li></allowedMeditationFocusTypes> 
          </li>
      </degreeDatas>
  </TraitDef>

