  <TraitDef>
      <defName>UT_Rabies</defName>
      <commonality>0.4</commonality>
      <degreeDatas>
          <li>
              <label>&lt;color=#b10000&gt;Rabid Madness&lt;/color&gt;</label>
              <description>An unknown virus damaged {PAWN_nameDef}'s nervous system, driving {PAWN_objective} into wild frenzy.</description>
              <statFactors>
