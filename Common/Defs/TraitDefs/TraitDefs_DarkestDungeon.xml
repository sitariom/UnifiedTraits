          <li>Social</li> 
          <li>Intellectual</li> 
      </disabledWorkTags>
      <conflictingTraits> 
          <li>Kind</li> 
          <li>Wimp</li> 
          <li>UT_Natural</li> 
      </conflictingTraits>
  </TraitDef>

  <TraitDef>
      <defName>UT_Skinned</defName>
      <commonality>0.8</commonality>
      <degreeDatas>
          <li>
